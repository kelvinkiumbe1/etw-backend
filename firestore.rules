rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════
    //  HELPER FUNCTIONS
    // ══════════════════════════════════════════════════

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner() {
      return resource.data.uid == request.auth.uid;
    }

    function isClaimingOwn() {
      return request.resource.data.uid == request.auth.uid;
    }

    function hasRequiredFields() {
      return request.resource.data.keys().hasAll(['uid', 'pair', 'createdAt'])
          || request.resource.data.keys().hasAll(['uid', 'pair', 'updatedAt']);
    }

    function uidIsValid() {
      return request.resource.data.uid is string
          && request.resource.data.uid.size() > 0;
    }

    function isAdmin() {
      return isAuthed() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isMentorOf(studentUid) {
      return isAuthed() &&
        exists(/databases/$(database)/documents/mentorRelationships/$(request.auth.uid + '_' + studentUid));
    }

    function isStudentOf(mentorUid) {
      return isAuthed() &&
        exists(/databases/$(database)/documents/mentorRelationships/$(mentorUid + '_' + request.auth.uid));
    }

    function isInRelationshipWith(uid) {
      return isMentorOf(uid) || isStudentOf(uid);
    }

    // ── Public landing-page ticket validation ─────────────────────
    function isPublicLandingTicket() {
      let d = request.resource.data;
      return d.uid == 'guest'
          && d.source == 'landing_page'
          && d.keys().hasAll(['uid','userEmail','userName','subject','category','status','adminUnread','userUnread','source','createdAt','updatedAt'])
          && d.userEmail is string && d.userEmail.size() > 0 && d.userEmail.size() < 200
          && d.userName  is string && d.userName.size()  > 0 && d.userName.size()  < 100
          && d.subject   is string && d.subject.size()   > 0 && d.subject.size()   < 200
          && d.category  is string && d.category.size()  < 50
          && d.status      == 'open'
          && d.adminUnread == true
          && d.userUnread  == false
          && d.createdAt is int
          && d.updatedAt is int;
    }

    function isPublicLandingMessage(ticketId) {
      let d = request.resource.data;
      let ticket = get(/databases/$(database)/documents/supportTickets/$(ticketId)).data;
      return ticket.uid == 'guest'
          && ticket.source == 'landing_page'
          && d.role == 'user'
          && d.uid  == 'guest'
          && d.userName is string && d.userName.size() > 0 && d.userName.size() < 100
          && d.text is string && d.text.size() > 0 && d.text.size() <= 4000
          && d.ts is int;
    }

    function isGuestLandingTicket(ticketId) {
      let ticket = get(/databases/$(database)/documents/supportTickets/$(ticketId)).data;
      return ticket.uid == 'guest'
          && ticket.source == 'landing_page';
    }

    function isPublicLandingTicketUpdate(ticketId) {
      return isGuestLandingTicket(ticketId)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['updatedAt', 'userUnread', 'adminUnread']);
    }

    // ══════════════════════════════════════════════════
    //  TRADES COLLECTION
    // ══════════════════════════════════════════════════
    match /trades/{tradeId} {
      allow read:   if isAuthed() && (
        isOwner() ||
        isMentorOf(resource.data.uid) ||
        isStudentOf(resource.data.uid)
      );
      allow create: if isAuthed() && isClaimingOwn() && uidIsValid() && hasRequiredFields();
      allow update: if isAuthed() && isOwner() && isClaimingOwn() && uidIsValid();
      allow delete: if isAuthed() && isOwner();
    }

    // ══════════════════════════════════════════════════
    //  PLAYBOOKS COLLECTION
    // ══════════════════════════════════════════════════
    match /playbooks/{playbookId} {
      allow read:   if isAuthed() && (
        isOwner() ||
        isMentorOf(resource.data.uid) ||
        isStudentOf(resource.data.uid)
      );
      allow create: if isAuthed() && isClaimingOwn() && uidIsValid();
      allow update: if isAuthed() && isOwner() && isClaimingOwn() && uidIsValid();
      allow delete: if isAuthed() && isOwner();
    }

    // ══════════════════════════════════════════════════
    //  TRADING RULES COLLECTION
    // ══════════════════════════════════════════════════
    match /trading_rules/{ruleId} {
      allow read:   if isAuthed() && isOwner();
      allow create: if isAuthed() && isClaimingOwn() && uidIsValid();
      allow update: if isAuthed() && isOwner() && isClaimingOwn() && uidIsValid();
      allow delete: if isAuthed() && isOwner();
    }

    // ══════════════════════════════════════════════════
    //  PUBLIC SHARES COLLECTION
    // ══════════════════════════════════════════════════
    match /publicShares/{shareId} {
      allow read:   if true;
      allow create: if isAuthed() && isClaimingOwn() && uidIsValid();
      allow update: if isAuthed() && isOwner() && isClaimingOwn() && uidIsValid();
      allow delete: if isAuthed() && isOwner();
    }

    // ══════════════════════════════════════════════════
    //  PRESENCE COLLECTION
    // ══════════════════════════════════════════════════
    match /presence/{uid} {
      allow read:  if isAuthed() && (
        request.auth.uid == uid ||
        isInRelationshipWith(uid)
      );
      allow write: if isAuthed() && request.auth.uid == uid;
    }

    // ══════════════════════════════════════════════════
    //  ADMINS COLLECTION
    // ══════════════════════════════════════════════════
    match /admins/{adminUid} {
      allow read:  if isAuthed() && request.auth.uid == adminUid;
      allow write: if false;
    }

    // ══════════════════════════════════════════════════
    //  USER DOCUMENT  (FIX 2 — added)
    //  The app reads users/{uid} for broker/cTrader connection status
    //  (connRefresh onSnapshot) and writes settings (e.g. mt5ApiKey).
    //  Without this rule those reads/writes fall through to the final
    //  deny. Backend broker-status writes use the Admin SDK (bypass rules).
    // ══════════════════════════════════════════════════
    match /users/{uid} {
      allow read:  if isAuthed() && (request.auth.uid == uid || isAdmin());
      allow write: if isAuthed() && request.auth.uid == uid;
    }

    // ══════════════════════════════════════════════════
    //  USERS SUB-COLLECTIONS
    //  FIX 1 — `collection != 'private'` seals users/{uid}/private/**
    //  (cTrader OAuth access/refresh tokens) from ALL client access.
    //  The backend Admin SDK bypasses rules, so server sync still works.
    // ══════════════════════════════════════════════════
    match /users/{uid}/{collection}/{docId} {
      allow read, write: if isAuthed() && request.auth.uid == uid && collection != 'private';
      allow read: if isAuthed() &&
        isMentorOf(uid) &&
        collection in ['trades', 'playbooks'];
    }

    // ══════════════════════════════════════════════════
    //  SUPPORT TICKETS COLLECTION
    // ══════════════════════════════════════════════════
    match /supportTickets/{ticketId} {
      // Read own tickets by uid OR by matching verified email (compatibility path
      // for tickets created under the same email but a different auth uid); admins
      // read all; guests read their own landing-page ticket.
      allow read: if (isAuthed() && (resource.data.uid == request.auth.uid || resource.data.userEmail == request.auth.token.email || isAdmin()))
        || (resource.data.uid == 'guest' && resource.data.source == 'landing_page');

      allow create: if (isAuthed() && isClaimingOwn() && uidIsValid())
        || isPublicLandingTicket();

      allow update: if (isAuthed() && (resource.data.uid == request.auth.uid || isAdmin()))
        || isPublicLandingTicketUpdate(ticketId);

      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if (isAuthed() && (
          get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.uid
            == request.auth.uid
          || isAdmin()
        )) || isGuestLandingTicket(ticketId);

        allow create: if (isAuthed() && (
          get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.uid
            == request.auth.uid
          || isAdmin()
        )) || isPublicLandingMessage(ticketId);

        allow update, delete: if false;
      }
    }

    // ══════════════════════════════════════════════════
    //  TIPS  (FIX 3 — added; app does addDoc('tips', …))
    // ══════════════════════════════════════════════════
    match /tips/{tipId} {
      allow create: if isAuthed();
      allow read:   if isAdmin();
      allow update, delete: if false;
    }

    // ══════════════════════════════════════════════════
    //  MENTOR INVITES
    // ══════════════════════════════════════════════════
    match /mentorInvites/{code} {
      allow read: if isAuthed();
      allow create: if isAuthed() &&
        request.resource.data.mentorUid == request.auth.uid;
      allow update: if isAuthed() && resource.data.mentorUid == request.auth.uid;
      allow delete: if isAuthed() && resource.data.mentorUid == request.auth.uid;
    }

    // ══════════════════════════════════════════════════
    //  MENTOR RELATIONSHIPS
    // ══════════════════════════════════════════════════
    match /mentorRelationships/{relationId} {
      allow read: if isAuthed() && (
        resource.data.mentorUid  == request.auth.uid ||
        resource.data.studentUid == request.auth.uid
      );
      allow list: if isAuthed();
      allow create: if isAuthed() &&
        request.resource.data.studentUid == request.auth.uid;
      allow update: if isAuthed() &&
        resource.data.studentUid == request.auth.uid &&
        request.resource.data.studentUid == request.auth.uid;
      allow delete: if isAuthed() && (
        resource.data.mentorUid  == request.auth.uid ||
        resource.data.studentUid == request.auth.uid
      );
    }

    // ══════════════════════════════════════════════════
    //  MENTOR CHAT
    // ══════════════════════════════════════════════════
    match /mentorChat/{relationId}/messages/{msgId} {
      allow read: if isAuthed() && (
        get(/databases/$(database)/documents/mentorRelationships/$(relationId)).data.mentorUid
          == request.auth.uid ||
        get(/databases/$(database)/documents/mentorRelationships/$(relationId)).data.studentUid
          == request.auth.uid
      );
      allow create: if isAuthed() && (
        get(/databases/$(database)/documents/mentorRelationships/$(relationId)).data.mentorUid
          == request.auth.uid ||
        get(/databases/$(database)/documents/mentorRelationships/$(relationId)).data.studentUid
          == request.auth.uid
      );
      allow update, delete: if false;
    }

    // ══════════════════════════════════════════════════
    //  PUBLIC INTERACTIONS (likes & comments)
    // ══════════════════════════════════════════════════
    match /publicInteractions/{shareId} {
      allow read, write: if false;

      match /likes/{likeId} {
        allow read: if true;
        allow create: if request.resource.data.count is int
                      && request.resource.data.count == 1
                      && request.resource.data.itemId is string
                      && request.resource.data.itemId.size() > 0;
        allow update: if request.resource.data.count is int
                      && (request.resource.data.count == resource.data.count + 1
                          || request.resource.data.count == resource.data.count - 1);
        allow delete: if false;
      }

      match /{commentCol}/{commentId} {
        allow read: if commentCol.matches('comments_[A-Za-z0-9]+');

        allow create: if commentCol.matches('comments_[A-Za-z0-9]+')
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 500
                      && request.resource.data.author is string
                      && request.resource.data.author.size() > 0
                      && request.resource.data.author.size() <= 40
                      && (request.resource.data.parentId == null
                          || (request.resource.data.parentId is string
                              && request.resource.data.parentId.size() > 0))
                      && (
                           !('isOwner' in request.resource.data)
                           || request.resource.data.isOwner == false
                           ||
                           (request.resource.data.isOwner == true
                             && isAuthed()
                             && get(/databases/$(database)/documents/publicShares/$(shareId)).data.uid
                                  == request.auth.uid)
                         );

        allow update: if commentCol.matches('comments_[A-Za-z0-9]+')
                      && isAuthed()
                      && get(/databases/$(database)/documents/publicShares/$(shareId)).data.uid
                           == request.auth.uid
                      && resource.data.isOwner != true
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedByOwner'])
                      && request.resource.data.likedByOwner is bool;

        allow delete: if commentCol.matches('comments_[A-Za-z0-9]+')
                      && (
                           resource.data.isOwner != true
                           ||
                           (isAuthed()
                             && get(/databases/$(database)/documents/publicShares/$(shareId)).data.uid
                                  == request.auth.uid)
                         );
      }
    }

    // ══════════════════════════════════════════════════
    //  BLOCK ALL OTHER COLLECTIONS
    // ══════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
